NODE_ENV=development
PORT=3000

# Public API origin for absolute image URLs (/uploads/...) — required in production for mobile
# Example: https://api.yourdomain.com (no trailing slash)
PUBLIC_BASE_URL=http://localhost:3000

# Swagger / OpenAPI / Postman «Servers»: not tied to PORT (avoids localhost:5003 when PORT=5003)
# SWAGGER_LOCAL_URL=http://localhost:3000/api
# SWAGGER_LOCAL_PORT=3000
# Force production server row (overrides deriving from PUBLIC_BASE_URL):
# SWAGGER_PROD_URL=https://etqan.nodeteam.site/api

# Database
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/etqan_db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=10

# Email (for OTP - nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@etqan.com
