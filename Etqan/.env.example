NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/etqan_db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=10

# Email (for OTP - nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@etqan.com
